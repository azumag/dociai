{
  "connectors": {
    "openai_main": {
      "provider": "openai",
      "apiKey": "sk-...",
      "model": "gpt-4.1-mini"
    },
    "openrouter_fun": {
      "provider": "openrouter",
      "apiKey": "or-...",
      "model": "anthropic/claude-3.5-haiku"
    },
    "vision_model": {
      "provider": "openai",
      "apiKey": "sk-...",
      "model": "gpt-4.1-mini"
    },
    "ollama_local": {
      "provider": "ollama",
      "model": "llama3.2",
      "baseUrl": "http://localhost:11434/v1"
    },
    "minimax_main": {
      "provider": "minimax",
      "apiKey": "sk-...",
      "model": "MiniMax-M3"
    },
    "mock_test": {
      "provider": "mock"
    }
  },
  "context": {
    "commentHistoryLimit": 80,
    "includeRecentComments": 20,
    "maxPromptChars": 4000,
    "screenCapture": {
      "enabled": true,
      "connector": "vision_model",
      "maxAgeSeconds": 120,
      "maxTokens": 768
    }
  },
  "voicevox": {
    "enabled": false,
    "baseUrl": "http://127.0.0.1:50021",
    "defaultSpeaker": 3,
    "maxChars": 200,
    "timeoutMs": 30000
  },
  "micMonitor": {
    "enabled": true,
    "threshold": 0.05,
    "minSpeechMs": 150,
    "silenceHoldMs": 800
  },
  "commentSources": {
    "twitch": {
      "enabled": false,
      "channels": ["your_twitch_channel"]
    }
  },
  "personas": [
    {
      "id": "partner_ai",
      "name": "相棒AI",
      "connector": "openai_main",
      "enabled": true,
      "systemPrompt": "あなたは配信者の相棒AIです。コメントと画面状況を踏まえ、短く自然に返します。",
      "triggers": ["mention_ai", "hotkey_partner"],
      "voice": {
        "enabled": true,
        "engine": "webspeech",
        "name": "default",
        "rate": 1.1,
        "pitch": 1.0
      }
    },
    {
      "id": "tsukkomi_ai",
      "name": "ツッコミAI",
      "connector": "openrouter_fun",
      "enabled": true,
      "systemPrompt": "あなたは配信のツッコミ役です。軽く茶化しつつ、失礼にならないよう短く返します。",
      "triggers": ["random_comment"],
      "voice": {
        "enabled": true,
        "engine": "voicevox",
        "speaker": 3,
        "speed": 1.1,
        "pitch": -0.05,
        "intonation": 1.1
      }
    },
    {
      "id": "mock_ai",
      "name": "テストAI(モック)",
      "connector": "mock_test",
      "enabled": true,
      "systemPrompt": "APIキーなしの動作確認用ペルソナです。",
      "triggers": ["mention_test", "hotkey_mock"],
      "voice": {
        "enabled": true,
        "name": "default",
        "rate": 1.0,
        "pitch": 1.0
      }
    }
  ],
  "triggers": {
    "mention_ai": {
      "type": "keyword",
      "keywords": ["AIさん", "どう思う", "解説して"]
    },
    "mention_test": {
      "type": "keyword",
      "keywords": ["テスト"]
    },
    "hotkey_partner": {
      "type": "hotkey",
      "keys": "Alt+1"
    },
    "hotkey_mock": {
      "type": "hotkey",
      "keys": "Alt+3"
    },
    "random_comment": {
      "type": "random",
      "probability": 0.2
    },
    "news_every_30min": {
      "type": "interval",
      "minutes": 30
    }
  },
  "router": {
    "defaultPersona": "partner_ai",
    "maxRepliesPerComment": 1,
    "cooldownSeconds": 8
  },
  "news": {
    "enabled": true,
    "trigger": "news_every_30min",
    "persona": "partner_ai",
    "mode": "topic",
    "sources": [
      {
        "name": "NHK",
        "type": "rss",
        "url": "https://www.nhk.or.jp/rss/news/cat0.xml"
      }
    ],
    "maxItems": 3,
    "dedupe": true,
    "style": "配信の合間に自然に読める短いニュース紹介にする"
  }
}
